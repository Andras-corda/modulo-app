{
  "name": "modulo",
  "version": "1.4.7",
  "description": "Application de productivité desktop modulaire",
  "author": "R3tr0___",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.modulo.app",
    "productName": "Modulo",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icons/icon.ico",
      "publisherName": "Andras Corda",
      "verifyUpdateCodeSignature": false,
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "assets/icons/icon.ico",
      "shortcutName": "Modulo"
    }
  }
}